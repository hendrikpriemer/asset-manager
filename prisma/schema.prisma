// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Asset {
  id                           String              @id @default(cuid())
  name                         String
  description                  String?
  structureNodeId              String?
  structureNode                AssetStructureNode? @relation(fields: [structureNodeId], references: [id], onDelete: SetNull)
  assetImage                   Bytes?
  assetImageType               String?
  nameplateImage               Bytes?
  nameplateImageType           String?
  aasEndpointUrl               String?
  aasGlobalAssetId             String?
  aasSearchText                String?
  aasSearchIndexedAt           DateTime?
  nameplateSubmodelGeneratedAt DateTime?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt

  @@index([structureNodeId])
}

model AasRepository {
  id            String   @id @default(cuid())
  name          String
  baseUrl       String   @unique
  isLocalMirror Boolean  @default(false)
  createdAt     DateTime @default(now())
}

enum VisionProviderType {
  ANTHROPIC
  OPENAI
  MISTRAL
}

// A single row, if present, configures the vision-API fallback used by the
// nameplate-photo identification feature when plain OCR can't extract an
// article number - see lib/vision-provider-settings.ts. No row means the
// fallback is disabled and OCR is used on its own.
model VisionProviderSetting {
  id              String             @id @default(cuid())
  provider        VisionProviderType
  model           String
  encryptedApiKey String
  updatedAt       DateTime           @updatedAt
}

enum AssetStructureLevel {
  ENTERPRISE
  SITE
  AREA
  WORK_CENTER
  EQUIPMENT
}

model AssetStructureNode {
  id           String               @id @default(cuid())
  level        AssetStructureLevel
  name         String
  description  String?
  address      String?
  timezone     String?
  manufacturer String?
  serialNumber String?
  position     Int                  @default(0)
  parentId     String?
  parent       AssetStructureNode?  @relation("AssetStructureNodeParent", fields: [parentId], references: [id], onDelete: Cascade)
  children     AssetStructureNode[] @relation("AssetStructureNodeParent")
  assets       Asset[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([parentId, position])
}
