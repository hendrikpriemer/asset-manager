// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Asset {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  structureNodeId    String?
  structureNode      AssetStructureNode? @relation(fields: [structureNodeId], references: [id], onDelete: SetNull)
  assetImage         Bytes?
  assetImageType     String?
  nameplateImage     Bytes?
  nameplateImageType String?
  aasEndpointUrl     String?
  aasGlobalAssetId   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([structureNodeId])
}

model AasRepository {
  id        String   @id @default(cuid())
  name      String
  baseUrl   String   @unique
  createdAt DateTime @default(now())
}

enum AssetStructureLevel {
  ENTERPRISE
  SITE
  AREA
  WORK_CENTER
  EQUIPMENT
}

model AssetStructureNode {
  id          String              @id @default(cuid())
  level       AssetStructureLevel
  name        String
  description String?
  position    Int                 @default(0)
  parentId    String?
  parent      AssetStructureNode?  @relation("AssetStructureNodeParent", fields: [parentId], references: [id], onDelete: Cascade)
  children    AssetStructureNode[] @relation("AssetStructureNodeParent")
  assets      Asset[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([parentId, position])
}
