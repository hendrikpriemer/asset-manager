POSTGRES_USER=asset_manager
POSTGRES_PASSWORD=change_me
POSTGRES_DB=asset_manager
DATABASE_URL="postgresql://asset_manager:change_me@db:5432/asset_manager?schema=public"
NODE_ENV=development
LOCAL_AAS_MIRROR_URL=http://basyx-aas-env:8081

# Encrypts secrets stored in the database (currently: the vision-provider API
# key, see src/lib/vision-provider-settings.ts). Must be a 64-character hex
# string (32 bytes). Generate one with: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=
